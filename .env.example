# =====================================================================
#  morfeu — variáveis de ambiente (copie para .env e ajuste)
#  cp .env.example .env
# =====================================================================

# --- FONTE ANATEL (recomendado: URL direta, SEM token) ---------------
# Cole aqui o link do recurso (CSV ou ZIP). Duas formas de obter:
#  (a) Portal ANATEL: https://www.anatel.gov.br/dadosabertos/PDA/...
#  (b) dados.gov.br: abra o conjunto da ANATEL, no recurso clique em
#      "Baixar" e copie o endereço do link.
# Exemplos de conjuntos com UF, município, latitude e longitude:
#  - Plano Básico de Radiodifusão (FM/TV): estações com lat/long/potência
#  - Estações licenciadas (SMP/SCM) do Mosaico
DADOSGOV_RESOURCE_URL=https://www.anatel.gov.br/dadosabertos/paineis_de_dados/outorga_e_licenciamento/estacoes_licenciadas.zip

# Se o recurso for um .zip com vários CSVs, escolha qual pelo nome (substring).
# Ex.: PBFM para o Plano Básico FM. Vazio = primeiro CSV do zip.
DADOSGOV_ZIP_MEMBER=

# Parsing do CSV da ANATEL (separador ; é praticamente universal; o encoding
# VARIA por recurso — confira com 'make headers' antes de assumir. O recurso
# padrão acima, por exemplo, é UTF-8 com BOM, não latin-1 apesar do que a
# documentação da ANATEL sugere).
DADOSGOV_CSV_SEP=;
DADOSGOV_CSV_ENCODING=utf-8-sig
DADOSGOV_MAX_ROWS=500
DADOSGOV_TIPO_NO=ESTACAO

# Mapeamento coluna_do_CSV -> campo do evento. Este já é o mapeamento válido
# para o recurso padrão acima (validado com 'make headers'); se trocar de
# recurso, rode 'make headers' de novo e ajuste. Este CSV não tem coluna de
# status de licenciamento — deixe vazio, o producer usa fallback "ATIVO".
DADOSGOV_FIELD_MAP={"id_no":"Número da Estação","id_no_pai":"","uf":"UF","municipio":"Município","latitude":"Latitude","longitude":"Longitude","status":""}

# ingest = publica no Kafka | headers = mostra as colunas do CSV | dump = JSON da API
DADOSGOV_MODE=ingest

# --- ALTERNATIVA: via API do dados.gov.br (exige token) --------------
# Só é necessário se você NÃO usar DADOSGOV_RESOURCE_URL acima.
# Token do perfil de consumidor:
# https://dados.gov.br/dados/conteudo/como-acessar-a-api-do-portal-de-dados-abertos-com-o-perfil-de-consumidor
DADOSGOV_API_TOKEN=
DADOSGOV_TOKEN_HEADER=chave-api-dados-abertos
DADOSGOV_BASE_URL=https://dados.gov.br/dados/api/publico
DADOSGOV_DATASET_ID=
DADOSGOV_RESOURCE_FORMAT=CSV

# --- Kafka -----------------------------------------------------------
KAFKA_BOOTSTRAP=kafka:9092
KAFKA_TOPIC=topologia.eventos

# --- Carga em lote (loader): datasets analíticos ANATEL ---------------
# Pasta no HOST com os .zip baixados manualmente dos painéis da ANATEL
# (acessos_banda_larga_fixa.zip, velocidade_contratada_scm.zip). Montada
# como somente-leitura em /raw dentro do container. Use 'make load-acessos'
# e 'make load-velocidade'.
ANATEL_RAW_DIR=./data/raw
